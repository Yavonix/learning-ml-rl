   ],
   "source": [
    "metric_learning_rates = Record()\n",
    "\n",
    "learning_rates = [1e-4, 1e-3, 1e-2, 1.0]\n",
    "for rate in learning_rates:\n",
    "    model = CNN(arch=[(1,32,0), (1,64,0)], classes=classes, batch_norm=True).set_name(f\"lr-{rate}\")\n",
    "    eval_model(model, metric_learning_rates, ds_train_t, ds_val_t, device, EPOCHS, lr=rate)"
   ]
  },
