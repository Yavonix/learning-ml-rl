   "source": [
    "model16 = CNN(arch=[(6,32,0), (5,64,0), (5,128,0)], classes=classes, batch_norm=True) # 6+5+5\n",
    "model32 = CNN(arch=[(8,32,0), (8,64,0), (8,128,0), (8,256,0)], classes=classes, batch_norm=True) # 8+8+8+8\n",
    "model16improved = CNN(arch=[(6,32,2), (5,64,2), (5,128,2)], classes=classes, dropout_rate=0.3, batch_norm=True)\n",
    "model32improved = CNN(arch=[(8,32,2), (8,64,2), (8,128,2), (8,256,2)], classes=classes, dropout_rate=0.3, batch_norm=True)\n",
    "\n",
    "models_improvement_comparison = [model16, model32, model16improved, model32improved]\n",
    "metrics_improvement_comparison = eval_models(models_improvement_comparison, EPOCHS, parallel=True, lr=1e-4)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "5f35faec-85b1-4b3e-9d9a-463506445a17",
   "metadata": {},
   "outputs": [],
   "source": [
    "def trim_record(record, max_epochs=30):\n",
    "    trimmed = Record()\n",
    "    for key, values in record.epoch_store.items():\n",
    "        trimmed.epoch_store[key] = values[:max_epochs]\n",
    "    return trimmed\n",
    "\n",
    "metrics_trimmed = trim_record(metrics_improvement_comparison, 30)"
   ]
  },
