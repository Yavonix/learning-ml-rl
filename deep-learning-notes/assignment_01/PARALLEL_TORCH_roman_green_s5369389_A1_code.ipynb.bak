{
 "cells": [
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "9a2bfd64",
   "metadata": {},
   "outputs": [],
   "source": [
    "from medmnist import PathMNIST\n",
    "import torch\n",
    "from torch import nn, utils, Generator\n",
    "import torch.nn.functional as F\n",
    "import torchvision\n",
    "# from tqdm import trange, tqdm\n",
    "from tqdm.notebook import trange, tqdm\n",
    "import plotly.express as px\n",
    "from typing import Sequence\n",
    "import plotly.express as px\n",
    "import plotly.io as pio\n",
    "pio.templates.default = \"simple_white\"\n",
    "import plotly.colors as pc\n",
    "\n",
    "import threading\n",
    "from concurrent.futures import ThreadPoolExecutor"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "6680009f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n",
      "NVIDIA GeForce RTX 5090\n"
     ]
    }
   ],
   "source": [
    "print(torch.cuda.is_available())\n",
    "print(torch.cuda.get_device_name(0)) \n",
    "EPOCHS = 30"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5730eaa7",
   "metadata": {},
   "source": [
    "## Dataset Preparation\n",
    "\n",
    "[MedMNIST](https://doi.org/10.1038/s41597-022-01721-8) is a collection of 18x standardized datasets for 2D and 3D biomedical image classification. \n",
    "\n",
    "It contains multiple size options: 28 (MNIST-Like), 64, 128, and 224."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "64ba44d2-733c-4bf7-90d8-d53c87e67498",
   "metadata": {},
   "outputs": [],
   "source": [
    "prepare_dataset = lambda x: PathMNIST(x, torchvision.transforms.ToTensor(), lambda x:x.squeeze(), download=True, root=\"/workspace\", size=128)\n",
    "ds_train, ds_val, ds_test = [prepare_dataset(x) for x in ['train', 'val', 'test']]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "2e9cb9a4",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "Dataset PathMNIST of size 128 (pathmnist_128)\n",
       "    Number of datapoints: 89996\n",
       "    Root location: /workspace\n",
       "    Split: train\n",
       "    Task: multi-class\n",
       "    Number of channels: 3\n",
       "    Meaning of labels: {'0': 'adipose', '1': 'background', '2': 'debris', '3': 'lymphocytes', '4': 'mucus', '5': 'smooth muscle', '6': 'normal colon mucosa', '7': 'cancer-associated stroma', '8': 'colorectal adenocarcinoma epithelium'}\n",
       "    Number of samples: {'train': 89996, 'val': 10004, 'test': 7180}\n",
       "    Description: The PathMNIST is based on a prior study for predicting survival from colorectal cancer histology slides, providing a dataset (NCT-CRC-HE-100K) of 100,000 non-overlapping image patches from hematoxylin & eosin stained histological images, and a test dataset (CRC-VAL-HE-7K) of 7,180 image patches from a different clinical center. The dataset is comprised of 9 types of tissues, resulting in a multi-class classification task. We resize the source images of 3×224×224 into 3×28×28, and split NCT-CRC-HE-100K into training and validation set with a ratio of 9:1. The CRC-VAL-HE-7K is treated as the test set.\n",
       "    License: CC BY 4.0"
      ]
     },
     "execution_count": 4,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Downloading the dataset from zenodo can take a long time, to speed up the process:\n",
    "# cd /var/tmp\n",
    "# aria2c -x 16 -s 16 \"https://zenodo.org/records/10519652/files/pathmnist_128.npz?download=1\" -o pathmnist_128.npz\n",
    "\n",
    "def preload(dataset):\n",
    "    X = torch.from_numpy(dataset.imgs).permute(0, 3, 1, 2).float() / 255.0\n",
    "    y = torch.from_numpy(dataset.labels).squeeze()\n",
    "    return utils.data.TensorDataset(X, y)\n",
    "\n",
    "ds_train_t = preload(ds_train)\n",
    "ds_val_t = preload(ds_val)\n",
    "ds_test_t = preload(ds_test)\n",
    "\n",
    "random_generator = Generator().manual_seed(42)\n",
    "prepare_dataloader = lambda x: utils.data.DataLoader(\n",
    "    x, 256, True,\n",
    "    generator=random_generator,\n",
    "    pin_memory=True,\n",
    ")\n",
    "\n",
    "dl_train, dl_val, dl_test = [prepare_dataloader(x) for x in [ds_train_t, ds_val_t, ds_test_t]]\n",
    "\n",
    "classes, label_lookup = len(ds_train.info['label']), ds_train.info['label']\n",
    "\n",
    "ds_train"
   ]
  },
